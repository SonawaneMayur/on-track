{
  "name": "ontrack",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Family task & routine app — on-device, iOS + Android via Capacitor.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview --host",
    "check": "svelte-check --tsconfig ./tsconfig.json",
    "sync": "cap sync",
    "ios": "cap run ios",
    "android": "cap run android",
    "open:ios": "cap open ios",
    "open:android": "cap open android"
  },
  "dependencies": {
    "@aparajita/capacitor-secure-storage": "8.0.0",
    "@capacitor-community/sqlite": "8.1.0",
    "@capacitor-community/speech-recognition": "7.0.1",
    "@capacitor-community/text-to-speech": "8.0.1",
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.4.0",
    "@capacitor/local-notifications": "8.2.0",
    "@capacitor/preferences": "8.0.1"
  },
  "devDependencies": {
    "@capacitor/android": "8.4.0",
    "@capacitor/cli": "8.4.0",
    "@capacitor/ios": "8.4.0",
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tsconfig/svelte": "5.0.5",
    "svelte": "5.56.3",
    "svelte-check": "4.6.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  }
}
